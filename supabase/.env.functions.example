# Stripe
STRIPE_SECRET_KEY=sk_test_or_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Supabase
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ALLOWED_ORIGINS=http://localhost:5173,https://staging.example.com,https://skiip.co.uk,https://www.skiip.co.uk

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxx
NOTIFICATION_FROM_EMAIL=orders@example.com
RESEND_WEBHOOK_SECRET=whsec_xxx
EMAIL_NOTIFICATION_EVENTS=order_paid,order_preparing,order_ready,order_cancelled,order_refunded

# WhatsApp via Twilio
WHATSAPP_PROVIDER=twilio
WHATSAPP_NOTIFICATION_EVENTS=order_ready
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_TOKEN=your_twilio_webhook_token
WHATSAPP_DEFAULT_COUNTRY_CODE=44
TWILIO_TEMPLATE_ORDER_READY=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_ORDER_PAID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_ORDER_PREPARING=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_ORDER_CANCELLED=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_ORDER_REFUNDED=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notification outbox / retry tuning
NOTIFICATION_DISPATCH_SECRET=your_notification_dispatch_secret
NOTIFICATION_DISPATCH_BATCH_SIZE=10
NOTIFICATION_DISPATCH_MAX_BATCHES_PER_RUN=3
NOTIFICATION_DISPATCH_MAX_ATTEMPTS=3
NOTIFICATION_PROCESSING_TIMEOUT_SECONDS=300
NOTIFICATION_RETRY_BASE_DELAY_SECONDS=60
